# =============================================================================
# SongSouls Environment Variables
# =============================================================================
# Copy to .env.local and fill in. None are required to start the app —
# every feature degrades gracefully if a key is missing.

# -----------------------------------------------------------------------------
# Anthropic — powers the live AI lyric preview on /create
# Get yours at https://console.anthropic.com/
# Without this, the lyric preview will show a friendly placeholder.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# -----------------------------------------------------------------------------
# Stripe — powers tiered checkout
# Get keys at https://dashboard.stripe.com/apikeys
# Without these, checkout falls back to "submit + we'll invoice you" mode.
# Use test keys (sk_test_…) while developing.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# Resend — sends order notifications to you and confirmations to customers
# Get a key at https://resend.com/api-keys
# Without this, orders are saved to ./data/orders.json and logged to console.
# -----------------------------------------------------------------------------
RESEND_API_KEY=
ORDER_NOTIFICATION_EMAIL=hello@songsouls.ai
ORDER_FROM_EMAIL=orders@songsouls.ai

# -----------------------------------------------------------------------------
# Admin — protects /admin route. Pick a long random string.
# -----------------------------------------------------------------------------
ADMIN_PASSWORD=change-me-to-something-long-and-random

# -----------------------------------------------------------------------------
# Public site URL — used for canonical URLs and Stripe redirects
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
