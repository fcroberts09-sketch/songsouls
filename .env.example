# =============================================================================
# SongSouls Environment Variables
# =============================================================================
# Copy to .env.local and fill in. The app boots without any of these (the
# free-draft path still works), but PAID checkout requires Stripe — see below.

# -----------------------------------------------------------------------------
# Anthropic — powers the live AI lyric preview on /create
# Get yours at https://console.anthropic.com/
# Without this, the lyric preview will show a friendly placeholder.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# -----------------------------------------------------------------------------
# Stripe — REQUIRED for paid checkout. Without these the "Pay $X" button
# returns 503 (we won't fake a successful order without payment).
#
# 1. Grab keys at https://dashboard.stripe.com/apikeys (use test keys in dev).
# 2. Create a webhook endpoint pointed at:
#       ${NEXT_PUBLIC_SITE_URL}/api/webhooks/stripe
#    Subscribe to: checkout.session.completed
#    Copy the signing secret into STRIPE_WEBHOOK_SECRET.
# 3. (Optional) Pre-create products and set the price IDs below.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional — use predefined Stripe products instead of inline pricing
STRIPE_PRICE_AI_CRAFTED=
STRIPE_PRICE_CURATED=
STRIPE_PRICE_LIFE_ALBUM=

# -----------------------------------------------------------------------------
# Resend — sends order notifications to you and confirmations to customers
# Get a key at https://resend.com/api-keys
# Without this, emails are logged to console (no actual delivery).
# -----------------------------------------------------------------------------
RESEND_API_KEY=
# Where new-order alerts go. OWNER_EMAIL is preferred; ORDER_NOTIFICATION_EMAIL
# is still honored for backward compatibility.
OWNER_EMAIL=hello@songsouls.ai
ORDER_NOTIFICATION_EMAIL=hello@songsouls.ai
ORDER_FROM_EMAIL=orders@songsouls.ai

# -----------------------------------------------------------------------------
# Firebase Firestore — persists orders for the admin dashboard.
# Without these, orders fall back to ./data/orders.json (single instance only).
#
# Create a service account at:
#   https://console.firebase.google.com → Project settings → Service accounts
# Download the JSON, then copy these fields:
#
#   FIREBASE_PROJECT_ID    = "project_id"
#   FIREBASE_CLIENT_EMAIL  = "client_email"
#   FIREBASE_PRIVATE_KEY   = "private_key"  (keep the \n escapes intact)
#
# When pasting FIREBASE_PRIVATE_KEY into a .env file, wrap it in double quotes
# so the literal \n stays a two-character escape — the app will convert them
# back to real newlines at runtime.
# -----------------------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Admin — protects /admin route. Pick a long random string.
# -----------------------------------------------------------------------------
ADMIN_PASSWORD=change-me-to-something-long-and-random

# -----------------------------------------------------------------------------
# Public site URL — used for canonical URLs and Stripe redirects.
# In production, set this to your real domain (no trailing slash).
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
